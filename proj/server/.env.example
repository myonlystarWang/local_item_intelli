# PostgreSQL connection required in production.
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/item_intelli

# Required by T2 authentication. Keep this long and random in production.
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=480

# Used only when admin_users is empty during first deployment.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-before-first-start

# Comma-separated explicit origins. Do not use "*".
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Keep false in production. Set true only for local development fallback.
ALLOW_SQLITE_FALLBACK=false
